# Database Configuration
POSTGRES_DB=book_exchange
POSTGRES_USER=book_exchange_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Application Configuration
APP_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Spring Datasource Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/book_exchange
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Email Configuration (Required for actual email sending)
# For Gmail: Create App Password at https://myaccount.google.com/apppasswords
# Leave empty to use console logging (development mode)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password

# JWT Configuration
JWT_SECRET=MySecretKeyForJWTTokenGenerationAndValidationShouldBeAtLeast256BitsLong
JWT_EXPIRATION=86400000

# Application URL (used in email verification links)
APP_BASE_URL=http://localhost:8080